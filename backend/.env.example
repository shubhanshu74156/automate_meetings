# Copy this file to .env and fill in your keys.
# The frontend lets users enter keys directly in the UI,
# so these are only needed if you want server-side defaults.

# STT providers
SARVAM_API_KEY=your_sarvam_api_key_here
OPENAI_API_KEY=your_openai_api_key_here   # also used for OpenAI LLM and OpenAI TTS
DEEPGRAM_API_KEY=your_deepgram_api_key_here
GROQ_API_KEY=your_groq_api_key_here       # also used for Groq LLM and Groq TTS

# LLM providers
CEREBRAS_API_KEY=your_cerebras_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_API_KEY=your_google_api_key_here
TOGETHER_API_KEY=your_together_api_key_here

# TTS providers
CARTESIA_API_KEY=your_cartesia_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

HOST=localhost
PORT=8000
